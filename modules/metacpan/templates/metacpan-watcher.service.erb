[Unit]
Description=<%= @description %>
Wants=basic.target
After=basic.target network.target

[Service]
WorkingDirectory=<%= @app_root %>
Environment=PATH=<%= @perlbin %>:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/home/<%= @user %>/bin/metacpan-api-carton-exec <%= @app_root %>/bin/metacpan watcher
User=metacpan
Group=users
KillMode=process
Restart=on-failure
RestartSec=60s

[Install]
WantedBy=multi-user.target
