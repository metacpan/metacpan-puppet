[Unit]
Description=<%= @description %>
Wants=basic.target
After=basic.target network.target

[Service]
WorkingDirectory=<%= @app_root %>
Environment=PATH=<%= @perlbin %>:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/home/<%= @user %>/bin/metacpan-api-carton-exec <%= @app_root %>/bin/api.pl minion worker -j <%= @workers %>
StandardOutput=append:<%= @app_root %>/var/log/minion_queue-stdout.log
StandardError=append:<%= @app_root %>/var/log/minion_queue-error.log
User=<%= @user %>
Group=<%= @group %>
KillMode=process
Restart=on-failure
RestartSec=60s

[Install]
WantedBy=multi-user.target
